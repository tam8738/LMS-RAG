# =====================================================
# LMS-RAG
# Environment Variables Example
# Copy this file to ".env" and update the values.
# =====================================================


# =====================================================
# PostgreSQL
# =====================================================

# Database host
# - localhost: khi chạy Backend ngoài Docker
# - postgres : Docker Compose sẽ tự ghi đè cho Backend container
DB_HOST=localhost

# Database port
DB_PORT=5432

# Database name
DB_NAME=lms_rag

# Database username
DB_USERNAME=postgres

# Database password
DB_PASSWORD=your_database_password


# =====================================================
# JWT
# =====================================================

# Base64 encoded secret key (>= 256 bits)
#
# Generate:
# https://www.base64encode.org/
#
# Example:
# openssl rand -base64 32
#
JWT_SECRET_BASE64=your_base64_secret_key

# Token expiration (milliseconds)
# 86400000 = 24 hours
JWT_EXPIRATION_MS=86400000


# =====================================================
# pgAdmin
# =====================================================

PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me


# =====================================================
# Spring
# =====================================================

SPRING_PROFILES_ACTIVE=docker