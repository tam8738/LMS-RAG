# ===== Database config (used by Spring Boot) =====
# Nếu chạy app bằng Docker Compose:
# - DB_HOST phải là tên service postgres (ví dụ: postgres)
# Nếu chạy app local (IDE/mvn spring-boot:run):
# - DB_HOST=localhost


DB_HOST=localhost
DB_PORT=5432
DB_NAME=lms_rag
DB_USERNAME=postgres
DB_PASSWORD=123456

PGADMIN_EMAIL=postgres
PGADMIN_PASSWORD=123456
# ===== JWT config =====
# Nên dùng chuỗi Base64 >= 32 bytes sau khi decode
# Ví dụ tạo nhanh:
# openssl rand -base64 32

JWT_SECRET_BASE64=REPLACE_ME_BASE64_SECRET
JWT_EXPIRATION_MS=3600000